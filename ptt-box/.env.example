# =============================================================================
# PTT Python Services 環境変数
# =============================================================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# Node.js Stream Server の設定は stream_server/.env.example を参照
# =============================================================================

# =============================================================================
# vox_ptt_record.py - VOX録音サービス
# =============================================================================
# マイクデバイス番号 (list_devices.py で確認)
VOX_DEVICE_INDEX=1
# 音量閾値 (RMS値、小さいほど敏感)
VOX_THRESHOLD=0.0020
# サンプルレート
VOX_SAMPLE_RATE=44100
# ブロックサイズ
VOX_BLOCK_SIZE=1024
# 無音判定のホールドカウント
VOX_HOLD_COUNT=3
# 無音後のホールド時間（秒）
VOX_HOLD_TIME=1.5
# 録音終了から保存までの待ち時間（秒）
VOX_SAVE_DELAY=10.0
# 録音ゲイン
VOX_GAIN=10.0
# Stream Server URL (PTT状態通知用)
STREAM_SERVER_URL=http://localhost:9320

# =============================================================================
# transcriber.py - Whisper文字起こしサービス
# =============================================================================
# Whisperモデルサイズ (tiny, base, small, medium, large-v2, large-v3)
WHISPER_MODEL_SIZE=large-v3
# 処理デバイス (cuda, cpu)
WHISPER_DEVICE=cuda
# 計算精度 (float16, int8, float32)
WHISPER_COMPUTE_TYPE=float16
# ログ設定
TRANSCRIBER_ENABLE_FILE_LOG=true
TRANSCRIBER_LOG_DIR=./logs

# =============================================================================
# 共通設定
# =============================================================================
# 録音ファイル保存ディレクトリ
RECORDINGS_DIR=./recordings

# =============================================================================
# ai_assistant.py / ai_assistant_agent.py - AI音声アシスタント
# =============================================================================
# 有効化フラグ (true/false)
ENABLE_AI_ASSISTANT=true
# OpenAI API Key (必須)
OPENAI_API_KEY=sk-...
# 使用モデル
AI_MODEL=gpt-5.4-mini
# 応答の最大トークン数 (ai_assistant.py のみ)
AI_RESPONSE_MAX_TOKENS=500
# ウェイクワード (カンマ区切り)
WAKE_WORDS=OKガーコ,okガーコ,オーケーガーコ,ガーコちゃん
# TTS音声 (edge-tts)
# 日本語: ja-JP-NanamiNeural, ja-JP-KeitaNeural
# 英語: en-US-JennyNeural, en-US-GuyNeural
TTS_VOICE=ja-JP-NanamiNeural
# TTS有効化 (true/false)
TTS_ENABLED=true
# サービスホスト/ポート (HTTP)
ASSISTANT_HOST=localhost
ASSISTANT_PORT=9321
# MCP設定ファイルパス
MCP_CONFIG_PATH=./mcp_config.json
# サンドボックスパス
SANDBOX_PATH=./sandbox
# ログ設定
ASSISTANT_ENABLE_FILE_LOG=true
ASSISTANT_LOG_DIR=./logs
ASSISTANT_LOG_RETENTION_DAYS=30
# デバッグモード (true/false) - ツール呼び出しの詳細をコンソールに表示
ASSISTANT_DEBUG=true
# デバッグ全文表示 (true/false) - trueで結果を省略せず全文表示
ASSISTANT_DEBUG_VERBOSE=false
# 会話履歴設定 (ai_assistant.py のみ)
# 保持する会話ペア数 (user+assistant で1ペア)
ASSISTANT_HISTORY_SIZE=10
# セッションタイムアウト（秒）- 無操作時に会話履歴をクリア
ASSISTANT_SESSION_TIMEOUT=300
# Agent SDK設定 (ai_assistant_agent.py のみ)
# 最大ツールループ回数
AGENT_MAX_TURNS=10
# セッションDBパス
AGENT_SESSION_DB=./sessions.db
# ツール出力の切り詰め閾値（文字数。これを超える古いターンの出力を切り詰め）
AGENT_TOOL_OUTPUT_MAX_CHARS=3000
# 切り詰め時に残すプレビュー文字数
AGENT_TOOL_OUTPUT_PREVIEW_CHARS=500

# =============================================================================
# vosk_realtime.py - Voskリアルタイム音声認識サービス
# =============================================================================
# WebSocketポート
VOSK_PORT=9322
# ホスト (0.0.0.0 で全インターフェース)
VOSK_HOST=0.0.0.0
# モデルパス (空の場合、ptt-box/ 以下の vosk-model* を自動検索)
VOSK_MODEL_PATH=
# サンプルレート (クライアントと合わせる)
VOSK_SAMPLE_RATE=16000

# =============================================================================
# MCP サーバー設定
# =============================================================================
# Tavily Web Search API Key (https://tavily.com で取得)
TAVILY_API_KEY=tvly-xxxxx
